{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BlurAutoClicker",
  "version": "3.4.1",
  "identifier": "com.djozman.BlurAutoClicker",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "BlurAutoClicker",
        "width": 500,
        "height": 150,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "maximizable": false,
        "shadow": false
      },
      {
        "label": "overlay",
        "url": "overlay.html",
        "title": "Overlay",
        "fullscreen": false,
        "width": 1,
        "height": 1,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": false,
        "skipTaskbar": true,
        "focusable": false,
        "acceptFirstMouse": false,
        "contentProtected": false,
        "visibleOnAllWorkspaces": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Djozman/Blur-AutoClickerMAC/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ0NEIyNzk5MkVDN0ZCMzEKUldReCs4Y3VtU2RMMUExaTFyU0RGVHVIZlUxOWo0QnRjUTArOElNdFZJeHdObUYrMU5wcGFPYzUK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "entitlements": "entitlements.plist",
      "infoPlist": "Info.plist"
    }
  }
}
